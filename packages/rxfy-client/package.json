{
  "name": "rxfy-client",
  "version": "3.1.0",
  "description": "framework-agnostic browser live runtime for rxfy — session identity and the live update sink",
  "keywords": [
    "rxfy",
    "rxjs",
    "reactive",
    "observable",
    "live",
    "realtime",
    "session",
    "websocket",
    "ssr",
    "typescript"
  ],
  "homepage": "https://rxfy.vanya2h.me",
  "bugs": {
    "url": "https://github.com/vanya2h/rxfy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanya2h/rxfy.git",
    "directory": "packages/rxfy-client"
  },
  "license": "MIT",
  "author": "hi@vanya2h.me",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "clean": "rimraf ./dist",
    "dev": "tsup --watch --silent",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "rxfy-protocol": "workspace:*"
  },
  "devDependencies": {
    "@vanya2h/eslint-config": "^0.7.0",
    "@vanya2h/typescript-config": "^0.7.0",
    "eslint": "^9.27.0",
    "jiti": "^2.4.2",
    "rimraf": "^6.0.1",
    "rxfy": "workspace:*",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.0",
    "vitest": "^3.1.4",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "rxfy": "^3.0.0-rc.0",
    "rxjs": "^7.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
