{
  "name": "rxfy-react",
  "version": "1.0.0",
  "description": "rxfy bindings for react",
  "homepage": "https://rxfy.vanya2h.me",
  "bugs": {
    "url": "https://github.com/vanya2h/rxfy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vanya2h/rxfy.git"
  },
  "author": "hi@vanya2h.me",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts",
      "default": "./dist/next.cjs"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "clean": "rimraf ./dist",
    "dev": "tsup --watch --silent",
    "lint": "eslint .",
    "prepublishOnly": "pnpm run build",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/lodash": "^4.17.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.27.0",
    "immutable": "^5.1.2",
    "jiti": "^2.4.2",
    "jsdom": "^26.1.0",
    "lodash": "^4.17.21",
    "p-queue": "^8.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rimraf": "^6.0.1",
    "rxfy": "workspace:*",
    "@vanya2h/eslint-config": "^0.4.0",
    "@vanya2h/typescript-config": "^0.4.0",
    "rxjs": "^7.8.2",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "vitest": "^3.1.4",
    "zod": "^3.25.42"
  },
  "peerDependencies": {
    "@types/react": "^18.0.0 || ^19.0.0",
    "lodash": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "rxfy": "workspace:*",
    "next": ">=14"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  }
}
