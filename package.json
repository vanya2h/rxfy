{
  "name": "root",
  "version": "0.0.0",
  "private": true,
  "description": "rxfy — a stream-based, normalized state management library built on RxJS",
  "keywords": [
    "rxjs",
    "reactive",
    "observable",
    "state-management",
    "store",
    "data-management",
    "normalization",
    "normalized-state",
    "atom",
    "lens",
    "optics",
    "ssr",
    "react",
    "zod",
    "typescript",
    "monorepo"
  ],
  "homepage": "https://rxfy.vanya2h.me",
  "bugs": {
    "url": "https://github.com/vanya2h/rxfy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vanya2h/rxfy.git"
  },
  "license": "MIT",
  "author": "hi@vanya2h.me",
  "type": "module",
  "scripts": {
    "bootstrap": "corepack pnpm install",
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:publish": "turbo run build && changeset publish",
    "changeset:version": "changeset version",
    "check-types": "turbo run check-types",
    "docs": "turbo run dev --filter=docs",
    "docs:docker": "docker compose up --build docs",
    "format": "prettier --write . --ignore-path .gitignore --ignore-path .prettierignore",
    "format:check": "prettier --check . --ignore-path .gitignore --ignore-path .prettierignore",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "sort-pkg": "sort-package-json \"package.json\" \"code/packages/*/package.json\" \"code/apps/*/package.json\"",
    "test": "turbo run test",
    "test:e2e": "turbo run e2e",
    "prepare": "husky"
  },
  "prettier": "@vanya2h/prettier-config",
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@types/node": "^22.15.29",
    "@vanya2h/eslint-config": "^0.7.0",
    "@vanya2h/prettier-config": "^0.7.0",
    "@vanya2h/typescript-config": "^0.7.0",
    "eslint": "^9.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.5.3",
    "sort-package-json": "^3.2.1",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  }
}
