    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "drizzle-orm": "^0.45.2",
    "lodash": "^4.17.21",
