  "private": true,
  "description": "rxfy live app: Next.js App Router + Hono + Drizzle/PGlite + real-time updates over WebSocket",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx server.mts",
    "build": "next build",
